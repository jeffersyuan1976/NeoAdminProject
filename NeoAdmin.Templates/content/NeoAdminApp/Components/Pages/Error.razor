@page "/Error"
@layout LayoutEmpty

<PageTitle>错误 - NeoAdmin</PageTitle>

<div class="error-page">
    <div class="error-card">
        <p class="error-label">发生错误</p>
        <h1>页面暂时不可用</h1>
        <p>
            系统遇到了一个未处理的异常，或者你访问的页面还没有接好。
            你可以先返回首页继续操作。
        </p>
        <a class="error-link" href="/">返回首页</a>
    </div>
</div>
