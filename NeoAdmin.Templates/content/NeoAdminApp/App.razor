    <script src="lib/quill/quill.js"></script>
    <script src='@Assets["_framework/blazor.web.js"]'></script>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // 走 SignalR 的交互式渲染模式。
    private static readonly IComponentRenderMode Interactive =
        new InteractiveServerRenderMode(prerender: false);

    // 标记了 [ExcludeFromInteractiveRouting] 的页面（如 Home、Error）走静态 SSR（返回 null），
    // 其余页面走 InteractiveServer。这样交互边界始终落在无参数的 <Routes> 上，可正常序列化。
    private IComponentRenderMode? RenderModeForPage =>
        HttpContext.AcceptsInteractiveRouting() ? Interactive : null;
}
