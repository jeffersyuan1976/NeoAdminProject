<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <DefaultItemExcludes>$(DefaultItemExcludes);**/neoadmin.db;**/neoadmin.db-*;**/wwwroot/uploads/**</DefaultItemExcludes>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <!-- 默认使用模板自带的 wwwroot/css/tailwind.css；需要重新生成时传 -p:BuildTailwind=true -->
    <BuildTailwind Condition="'$(BuildTailwind)' == ''">false</BuildTailwind>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NeoAdmin.Blazor" Version="1.0.29" />
    <PackageReference Include="NeoUI.Blazor" Version="4.1.7" />
    <PackageReference Include="Rougamo.Fody" Version="5.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Watch Remove="**/neoadmin.db" />
    <Watch Remove="**/neoadmin.db-*" />
    <Watch Remove="**/wwwroot/uploads/**" />
    <Watch Remove="**/node_modules/**" />
    <Content Update="wwwroot/uploads/**" Watch="false" />
    <None Update="neoadmin.db" Watch="false" />
    <None Update="neoadmin.db-*" Watch="false" />
  </ItemGroup>

  <!-- Tailwind v4：宿主业务页 utility -->
  <ItemGroup>
    <Content Remove="package.json" />
    <Content Remove="package-lock.json" />
    <Content Remove="tailwind.config.js" />
    <!-- 构建产物：纳入静态资源清单（Remove 避免与 SDK 默认 wwwroot 项重复） -->
    <Content Remove="wwwroot/css/tailwind.css" />
    <Content Include="wwwroot/css/tailwind.css" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="NpmInstall" BeforeTargets="BuildTailwindCss" Condition="'$(BuildTailwind)' == 'true' and Exists('$(ProjectDir)package.json')">
    <Exec Command="npm install" WorkingDirectory="$(ProjectDir)" />
  </Target>

  <Target Name="BuildTailwindCss" BeforeTargets="ResolveProjectStaticWebAssets" Condition="'$(BuildTailwind)' == 'true' and Exists('$(ProjectDir)package.json')">
    <Exec Command="npm run build:css" WorkingDirectory="$(ProjectDir)" />
  </Target>
</Project>
