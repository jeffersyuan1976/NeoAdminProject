<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NeoAdmin.Templates</PackageId>
    <Title>NeoAdmin.Templates</Title>
    <Version>1.0.0</Version>
    <Authors>NeoAdmin</Authors>
    <RepositoryUrl>https://github.com/3bDjrvHs50kiZIJb5/NeoAdminProject</RepositoryUrl>
    <PackageProjectUrl>https://github.com/3bDjrvHs50kiZIJb5/NeoAdminProject</PackageProjectUrl>
    <Description>NeoAdmin 的 dotnet new 项目模板，用于快速创建基于 Blazor Server、NeoUI 与 FreeSql 的后台管理项目。</Description>
    <PackageTags>dotnet-new;template;blazor;blazor-server;admin;neoadmin;neoui</PackageTags>
    <PackageType>Template</PackageType>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="content\**\*" />
    <EmbeddedResource Remove="content\**\*" />
    <None Remove="content\**\*" />
    <Content Include="content\**\*" Pack="true" PackagePath="content" Exclude="content\**\bin\**;content\**\obj\**;content\**\Logs\**;content\**\*.db;content\**\*.db-*" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
