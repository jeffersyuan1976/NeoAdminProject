@page "/neo-demo/ui/feedback"
@layout LayoutAdmin
@inject IToastService ToastService
@implements IDisposable
@inject ILogger<FeedbackDemo> Logger

<PageTitle>反馈组件演示</PageTitle>

<div class="neo-admin-page-scroll flex min-h-0 flex-1 flex-col gap-4 p-1">
    <div class="rounded-xl border bg-card text-card-foreground shadow-sm">
        <div class="border-b px-4 py-3">
            <strong class="text-base font-semibold">反馈组件</strong>
            <p class="mt-1 text-sm text-muted-foreground">
                Alert、Progress、Spinner、Toast — 提示、进度、加载与临时通知。
                参考 <a class="text-primary underline-offset-4 hover:underline"
                       href="https://demos.neoui.io/components"
                       target="_blank"
                       rel="noopener noreferrer">NeoUI Components</a>。
            </p>
        </div>

        <div class="p-4">
            <SearchableTabs DefaultValue="alert" Class="w-full">
                <TabsList Class="flex flex-wrap gap-1">
                    <TabsTrigger Value="alert">Alert</TabsTrigger>
                    <TabsTrigger Value="progress">Progress</TabsTrigger>
                    <TabsTrigger Value="spinner">Spinner</TabsTrigger>
                    <TabsTrigger Value="toast">Toast</TabsTrigger>
                </TabsList>

                <TabsContent Value="alert" Class="mt-4">
                    <DemoSection Title="Alert"
                                 Description="Displays callouts for important information or feedback"
                                 Code="@FeedbackDemoSnippets.Alert">
                        <div class="grid max-w-2xl gap-3">
                            <Alert Variant="AlertVariant.Default" AccentBorder="true">
                                <Icon>
                                    <LucideIcon Name="info" Class="h-4 w-4" />
                                </Icon>
                                <ChildContent>
                                    <AlertTitle>提示</AlertTitle>
                                    <AlertDescription>这是一条默认样式的提示信息，用于一般说明。</AlertDescription>
                                </ChildContent>
                            </Alert>

                            <Alert Variant="AlertVariant.Success" AccentBorder="true">
                                <Icon>
                                    <LucideIcon Name="circle-check" Class="h-4 w-4" />
                                </Icon>
                                <ChildContent>
                                    <AlertTitle>成功</AlertTitle>
                                    <AlertDescription>操作已成功完成，数据已保存。</AlertDescription>
                                </ChildContent>
                            </Alert>

                            <Alert Variant="AlertVariant.Warning" AccentBorder="true">
                                <Icon>
                                    <LucideIcon Name="triangle-alert" Class="h-4 w-4" />
                                </Icon>
                                <ChildContent>
                                    <AlertTitle>警告</AlertTitle>
                                    <AlertDescription>部分字段未填写，提交前请确认。</AlertDescription>
                                </ChildContent>
                            </Alert>

                            <Alert Variant="AlertVariant.Destructive" AccentBorder="true">
                                <Icon>
                                    <LucideIcon Name="circle-x" Class="h-4 w-4" />
                                </Icon>
                                <ChildContent>
                                    <AlertTitle>错误</AlertTitle>
                                    <AlertDescription>提交失败，请检查网络连接后重试。</AlertDescription>
                                </ChildContent>
                            </Alert>

                            <Alert Variant="AlertVariant.Info" AccentBorder="true">
                                <Icon>
                                    <LucideIcon Name="lightbulb" Class="h-4 w-4" />
                                </Icon>
                                <ChildContent>
                                    <AlertTitle>说明</AlertTitle>
                                    <AlertDescription>可通过 AccentBorder 强调左侧边框，配合 Icon 提升可读性。</AlertDescription>
                                </ChildContent>
                            </Alert>
                        </div>
                    </DemoSection>
                </TabsContent>

                <TabsContent Value="progress" Class="mt-4">
                    <DemoSection Title="Progress"
                                 Description="Progress bars with ARIA support and animations"
                                 Code="@FeedbackDemoSnippets.Progress">
                        <div class="max-w-md space-y-6">
                            <div class="space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span>静态示例</span>
                                    <span class="text-muted-foreground">33%</span>
                                </div>
                                <Progress Value="33" Max="100" Class="w-full" />
                            </div>

                            <div class="space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span>交互示例</span>
                                    <span class="text-muted-foreground">@progressValue%</span>
                                </div>
                                <Progress Value="@progressValue" Max="100" Class="w-full" />
                                <div class="flex flex-wrap gap-2 pt-1">
                                    <Button Size="ButtonSize.Small" OnClick="SimulateProgressAsync" Disabled="@isSimulating">
                                        @(isSimulating ? "模拟中…" : "模拟上传")
                                    </Button>
                                    <Button Variant="ButtonVariant.Outline"
                                            Size="ButtonSize.Small"
                                            OnClick="ResetProgress">
                                        重置
                                    </Button>
                                </div>
                            </div>

                            <div class="space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span>自定义最大值</span>
                                    <span class="text-muted-foreground">@stepProgress / @stepMax</span>
                                </div>
                                <Progress Value="@stepProgress" Max="@stepMax" Class="w-full" />
                                <div class="flex flex-wrap gap-2">
                                    <Button Variant="ButtonVariant.Outline"
                                            Size="ButtonSize.Small"
                                            OnClick="() => stepProgress = Math.Max(0, stepProgress - 1)">
                                        上一步
                                    </Button>
                                    <Button Variant="ButtonVariant.Outline"
                                            Size="ButtonSize.Small"
                                            OnClick="() => stepProgress = Math.Min(stepMax, stepProgress + 1)">
                                        下一步
                                    </Button>
                                </div>
                            </div>
                        </div>
                    </DemoSection>
                </TabsContent>

                <TabsContent Value="spinner" Class="mt-4">
                    <DemoSection Title="Spinner"
                                 Description="Loading indicators in multiple sizes"
                                 Code="@FeedbackDemoSnippets.Spinner">
                        <div class="space-y-8">
                            <div class="flex flex-wrap items-end gap-8">
                                <div class="flex flex-col items-center gap-2">
                                    <Spinner Size="SpinnerSize.Small" />
                                    <span class="text-xs text-muted-foreground">Small</span>
                                </div>
                                <div class="flex flex-col items-center gap-2">
                                    <Spinner Size="SpinnerSize.Medium" />
                                    <span class="text-xs text-muted-foreground">Medium</span>
                                </div>
                                <div class="flex flex-col items-center gap-2">
                                    <Spinner Size="SpinnerSize.Large" />
                                    <span class="text-xs text-muted-foreground">Large</span>
                                </div>
                            </div>

                            <div class="flex flex-wrap items-center gap-4">
                                <Button Disabled="true">
                                    <Spinner Size="SpinnerSize.Small" Class="mr-2" />
                                    加载中…
                                </Button>
                                <div class="flex items-center gap-2 text-sm text-muted-foreground">
                                    <Spinner Size="SpinnerSize.Small" />
                                    <span>正在获取数据</span>
                                </div>
                            </div>

                            <div>
                                <Button Variant="ButtonVariant.Outline"
                                        Size="ButtonSize.Small"
                                        OnClick="ToggleSpinnerPanel">
                                    @(showSpinnerPanel ? "隐藏" : "显示") 加载面板
                                </Button>
                                @if (showSpinnerPanel)
                                {
                                    <div class="mt-4 flex h-32 items-center justify-center rounded-lg border border-dashed">
                                        <Spinner Size="SpinnerSize.Medium" />
                                    </div>
                                }
                            </div>
                        </div>
                    </DemoSection>
                </TabsContent>

                <TabsContent Value="toast" Class="mt-4">
                    <DemoSection Title="Toast"
                                 Description="Temporary notifications with variants and actions"
                                 Code="@FeedbackDemoSnippets.Toast">
                        <p class="mb-4 text-sm text-muted-foreground">
                            页面需包含 <code class="text-xs">ToastViewport</code>（LayoutAdmin 已配置）。点击下方按钮触发通知。
                        </p>
                        <div class="flex flex-wrap gap-2">
                            <Button Size="ButtonSize.Small" OnClick="ShowSuccessToast">成功</Button>
                            <Button Variant="ButtonVariant.Destructive"
                                    Size="ButtonSize.Small"
                                    OnClick="ShowErrorToast">
                                错误
                            </Button>
                            <Button Variant="ButtonVariant.Outline"
                                    Size="ButtonSize.Small"
                                    OnClick="ShowWarningToast">
                                警告
                            </Button>
                            <Button Variant="ButtonVariant.Secondary"
                                    Size="ButtonSize.Small"
                                    OnClick="ShowInfoToast">
                                信息
                            </Button>
                            <Button Variant="ButtonVariant.Outline"
                                    Size="ButtonSize.Small"
                                    OnClick="ShowDefaultToast">
                                默认
                            </Button>
                            <Button Variant="ButtonVariant.Ghost"
                                    Size="ButtonSize.Small"
                                    OnClick="ShowActionToast">
                                带操作
                            </Button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(toastActionMessage))
                        {
                            <p class="mt-3 text-sm text-muted-foreground">@toastActionMessage</p>
                        }
                    </DemoSection>
                </TabsContent>
            </SearchableTabs>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => DemoPageLog.Enter(Logger, "反馈组件演示");
    private int progressValue;
    private bool isSimulating;
    private CancellationTokenSource? progressCts;

    private int stepProgress = 2;
    private const int stepMax = 5;

    private bool showSpinnerPanel;

    private string toastActionMessage = string.Empty;

    private async Task SimulateProgressAsync()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "SimulateProgressAsync");
        if (isSimulating)
        {
            return;
        }

        progressCts?.Cancel();
        progressCts?.Dispose();
        progressCts = new CancellationTokenSource();
        CancellationToken token = progressCts.Token;

        isSimulating = true;
        progressValue = 0;

        try
        {
            while (progressValue < 100 && !token.IsCancellationRequested)
            {
                await Task.Delay(80, token);
                progressValue = Math.Min(100, progressValue + 5);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
            // 用户重置或离开页面
        }
        finally
        {
            isSimulating = false;
        }
    }

    private void ResetProgress()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ResetProgress");
        progressCts?.Cancel();
        progressValue = 0;
        isSimulating = false;
    }

    private void ToggleSpinnerPanel()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ToggleSpinnerPanel");
        showSpinnerPanel = !showSpinnerPanel;
    }

    private void ShowSuccessToast()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ShowSuccessToast");
        ToastService.Success("操作成功", "您的更改已保存。");
    }

    private void ShowErrorToast()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ShowErrorToast");
        ToastService.Error("操作失败", "请稍后重试或联系管理员。");
    }

    private void ShowWarningToast()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ShowWarningToast");
        ToastService.Warning("注意", "此操作可能影响现有数据。");
    }

    private void ShowInfoToast()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ShowInfoToast");
        ToastService.Info("提示", "新版本功能说明已更新。");
    }

    private void ShowDefaultToast()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ShowDefaultToast");
        ToastService.Show("通知", "这是一条默认样式的 Toast。", ToastVariant.Default);
    }

    private void ShowActionToast()
    {
        DemoPageLog.Action(Logger, "反馈组件演示", "ShowActionToast");
        toastActionMessage = string.Empty;
        ToastService.Show(new ToastOptions
        {
            Title = "已删除",
            Description = "记录已从列表中移除。",
            Variant = ToastVariant.Default,
            ActionLabel = "撤销",
            OnAction = () =>
            {
                toastActionMessage = "已点击「撤销」操作。";
                ToastService.Info("撤销", "操作已恢复。");
                InvokeAsync(StateHasChanged);
            }
        });
    }

    public void Dispose()
    {
        progressCts?.Cancel();
        progressCts?.Dispose();
    }
}
