@page "/Blog/Classify"
@namespace NeoAdmin.Components.Blog
@layout LayoutAdmin
@using Microsoft.AspNetCore.Components.Forms
@using NeoAdmin.Blazor.Components
@using NeoAdmin.Blazor.Extensions
@using NeoAdmin.Blazor.Services
@inject IFreeSql FreeSql
@inject FileService FileService
@inject NavigationManager NavigationManager
@inject IToastService ToastService
@inject ILogger<Classify> Logger

<PageTitle>随笔专栏</PageTitle>

<div class="flex flex-col flex-1 min-h-0 overflow-hidden">
    <CrudTable @ref="table"
               TItem="BlogClassify"
               Title="随笔专栏"
               PageSize="50"
               SearchPlaceholder="专栏名称 / 创建者.."
               InitQuery="InitQuery"
               OnQuery="HandleQuery"
               OnEdit="HandleEdit"
               DialogContentSize="CrudDialogContentSize.Lg">
        <Columns>
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="long"
                             Property="@(row => row.Item.Id)"
                             Header="ID"
                             Sortable="false"
                             Width="180px" />
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="string"
                             Property="@(row => row.Item.ClassifyName)"
                             Header="分类专栏名称"
                             Sortable="false" />
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="int"
                             Property="@(row => row.Item.SortCode)"
                             Header="排序"
                             Sortable="false"
                             Width="80px" />
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="int"
                             Property="@(row => row.Item.ArticleCount)"
                             Header="随笔数量"
                             Sortable="false"
                             Width="96px" />
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="string"
                             Property="@(row => row.Item.Thumbnail)"
                             Header="封面图"
                             Sortable="false"
                             Width="96px">
                <CellTemplate Context="row">
                    @if (!string.IsNullOrWhiteSpace(row.Item.Thumbnail))
                    {
                        <img src="@NavigationManager.ToMediaUrl(row.Item.Thumbnail)"
                             alt="封面图"
                             class="h-10 w-10 rounded border object-cover" />
                    }
                    else
                    {
                        <span class="text-muted-foreground">-</span>
                    }
                </CellTemplate>
            </DataTableColumn>
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="string"
                             Property="@(row => row.Item.CreatedUserName)"
                             Header="创建者"
                             Sortable="false"
                             Width="120px" />
            <DataTableColumn TData="CrudGridRow<BlogClassify>"
                             TValue="string"
                             Property="@(_ => string.Empty)"
                             Header="创建时间"
                             Sortable="false"
                             Width="160px">
                <CellTemplate Context="row">
                    @(row.Item.CreatedTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")
                </CellTemplate>
            </DataTableColumn>
        </Columns>
        <EditTemplate Context="item">
            <div class="space-y-2">
                <Label For="classify-name">分类专栏名称</Label>
                <Input id="classify-name" Class="w-full" MaxLength="50" @bind-Value="item.ClassifyName" />
            </div>
            <div class="space-y-2">
                <Label For="classify-sort">排序</Label>
                <Input id="classify-sort"
                       Type="InputType.Number"
                       Class="w-full"
                       Value="@item.SortCode.ToString()"
                       ValueChanged="@(v => item.SortCode = int.TryParse(v, out var n) ? n : 0)" />
            </div>
            <div class="space-y-2">
                <Label For="classify-count">随笔数量</Label>
                <Input id="classify-count"
                       Type="InputType.Number"
                       Class="w-full"
                       Value="@item.ArticleCount.ToString()"
                       ValueChanged="@(v => item.ArticleCount = int.TryParse(v, out var n) ? n : 0)" />
            </div>
            <div class="space-y-2">
                <Label For="classify-thumb">封面图</Label>
                @if (!string.IsNullOrWhiteSpace(item.Thumbnail))
                {
                    <div class="rounded-lg border bg-muted/30 p-3">
                        <p class="mb-2 text-xs text-muted-foreground">当前封面</p>
                        <img src="@NavigationManager.ToMediaUrl(item.Thumbnail)"
                             alt="封面预览"
                             class="h-32 max-w-full rounded-md border bg-background object-cover" />
                    </div>
                    <Button Type="ButtonType.Button"
                            Variant="ButtonVariant.Ghost"
                            Size="ButtonSize.Small"
                            OnClick="@(() => ClearThumbnail(item))">
                        清除封面
                    </Button>
                }
                <FileUpload @ref="thumbnailUpload"
                            Files="thumbnailFiles"
                            FilesChanged="@(files => OnThumbnailFilesChangedAsync(item, files))"
                            Multiple="false"
                            Accept="image/*"
                            MaxFileSize="5242880"
                            ShowPreview="true"
                            Disabled="isUploadingThumbnail" />
                <p class="text-xs text-muted-foreground">仅支持图片，最大 5MB；选择后自动上传。</p>
            </div>
        </EditTemplate>
    </CrudTable>
</div>

@code {
    private CrudTable<BlogClassify> table = default!;
    private FileUpload? thumbnailUpload;
    private List<IBrowserFile> thumbnailFiles = [];
    private bool isUploadingThumbnail;

    private Task InitQuery(CrudQueryInfo e)
    {
        e.Filters = [];
        return Task.CompletedTask;
    }

    private void HandleQuery(CrudQueryEventArgs<BlogClassify> e)
    {
        e.Select!
            .WhereIf(!string.IsNullOrWhiteSpace(e.SearchText),
                a => a.ClassifyName.Contains(e.SearchText!)
                     || a.CreatedUserName.Contains(e.SearchText!))
            .OrderByDescending(a => a.Id);
    }

    private Task HandleEdit(BlogClassify item)
    {
        thumbnailFiles = [];
        isUploadingThumbnail = false;
        return Task.CompletedTask;
    }

    private async Task OnThumbnailFilesChangedAsync(BlogClassify item, List<IBrowserFile> files)
    {
        thumbnailFiles = files;
        if (files.Count == 0 || isUploadingThumbnail)
        {
            return;
        }

        isUploadingThumbnail = true;
        Logger.LogInformation("上传随笔专栏封面开始，ClassifyId={ClassifyId}", item.Id);
        try
        {
            var file = await FileService.UploadFileAsync(files[0], "blog/classify", isRename: true);
            item.Thumbnail = file.LinkUrl;
            ToastService.Success("封面图", "上传成功");
            Logger.LogInformation("上传随笔专栏封面成功，ClassifyId={ClassifyId}，Url={Url}", item.Id, file.LinkUrl);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "上传随笔专栏封面失败，ClassifyId={ClassifyId}", item.Id);
            ToastService.Error("封面图上传失败", ex.Message);
        }
        finally
        {
            thumbnailFiles = [];
            if (thumbnailUpload is not null)
            {
                await thumbnailUpload.ClearFiles();
            }

            isUploadingThumbnail = false;
        }
    }

    private async Task ClearThumbnail(BlogClassify item)
    {
        item.Thumbnail = string.Empty;
        thumbnailFiles = [];
        if (thumbnailUpload is not null)
        {
            await thumbnailUpload.ClearFiles();
        }
    }
}
