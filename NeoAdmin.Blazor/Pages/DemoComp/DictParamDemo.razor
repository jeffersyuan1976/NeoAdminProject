@page "/neo-demo/comp/dict-param"
@layout LayoutAdmin
@using Microsoft.Extensions.Logging
@using NeoAdmin.Blazor.Components
@using NeoAdmin.Blazor.Data.Entities
@using NeoAdmin.Blazor.Pages.DemoUI
@inject ILogger<DictParamDemo> Logger

<PageTitle>字典和参数配置演示</PageTitle>

<div class="flex flex-col gap-4 p-1">
    <div class="rounded-xl border bg-card text-card-foreground shadow-sm">
        <div class="border-b px-4 py-3">
            <strong class="text-base font-semibold">字典和参数配置演示</strong>
            <p class="mt-1 text-sm text-muted-foreground">
                字典选择与参数读取两种常见场景，通过标签页切换查看。
            </p>
        </div>

        <div class="p-4">
            <SearchableTabs DefaultValue="dict" Class="w-full">
                <div class="overflow-x-auto pb-1">
                    <TabsList Class="inline-flex h-auto w-max min-w-full flex-wrap gap-1">
                        <TabsTrigger Value="dict">字典演示</TabsTrigger>
                        <TabsTrigger Value="param">参数配置</TabsTrigger>
                    </TabsList>
                </div>

                <TabsContent Value="dict" Class="mt-4">
                    <DemoSection Title="NeoSelectDict"
                                 Description="按 ParentName 加载字典项，可在 /admin/dict 维护 Gender 等分类。"
                                 Code="@DictParamDemoSnippets.Dict">
                        <p class="mb-3 text-sm text-muted-foreground">
                            字典分类使用 <code class="rounded bg-muted px-1">Gender</code>，可在
                            <a class="text-primary underline-offset-4 hover:underline" href="/admin/dict">/admin/dict</a>
                            中直接维护。
                        </p>

                        <div class="max-w-md rounded-lg border border-[#d7e9e6] bg-[#edf6f5] p-3">
                            <label class="mb-2 block text-sm font-semibold text-[#244b50]">性别字典</label>
                            <NeoSelectDict ParentName="Gender"
                                           @bind-Value="selectedGender"
                                           OnValueChanged="OnGenderChanged" />
                        </div>

                        <div class="mt-3 text-sm text-muted-foreground">
                            当前选中值：
                            <span class="font-semibold text-[#0f3d46]">
                                @(string.IsNullOrWhiteSpace(selectedGender) ? "未选择" : selectedGender)
                            </span>
                        </div>
                    </DemoSection>
                </TabsContent>

                <TabsContent Value="param" Class="mt-4">
                    <DemoSection Title="NeoParamText"
                                 Description="按 ParamKey 读取 SysParam 的 Value / Value2 / Value3 字段渲染文本。"
                                 Code="@DictParamDemoSnippets.Param">
                        <p class="mb-3 text-sm text-muted-foreground">
                            参数编码使用 <code class="rounded bg-muted px-1">Home_ContactCard</code>，当前卡片通过
                            <code class="rounded bg-muted px-1">NeoParamText</code> 读取
                            <code class="rounded bg-muted px-1">Value</code>、
                            <code class="rounded bg-muted px-1">Value2</code>、
                            <code class="rounded bg-muted px-1">Value3</code>。<br />
                            你可以前往
                            <a class="text-primary underline-offset-4 hover:underline" href="/admin/param">/admin/param</a>
                            新增或修改这个参数。
                        </p>

                        <div class="max-w-lg rounded-lg border border-dashed border-[#d7c4a1] bg-[#f6f2ea] p-3">
                            <div class="mb-1 text-sm text-[#8a6b3d]">当前参数编码</div>
                            <div class="font-semibold text-[#3b2c18]">Home_ContactCard</div>

                            <div class="mb-1 mt-3 text-sm text-[#8a6b3d]">标题</div>
                            <NeoParamText ParamKey="Home_ContactCard"
                                          Field="@nameof(SysParam.Value)"
                                          DefaultText="未配置"
                                          TagName="div"
                                          Style="color: #2c241b;" />

                            <div class="mb-1 mt-3 text-sm text-[#8a6b3d]">正文</div>
                            <NeoParamText ParamKey="Home_ContactCard"
                                          Field="@nameof(SysParam.Value2)"
                                          DefaultText="未配置，请到 /admin/param 新增 Home_ContactCard 参数。"
                                          TagName="div"
                                          Style="color: #4b5563; line-height: 1.8;" />

                            <div class="mb-1 mt-3 text-sm text-[#8a6b3d]">联系电话</div>
                            <NeoParamText ParamKey="Home_ContactCard"
                                          Field="@nameof(SysParam.Value3)"
                                          DefaultText="未配置"
                                          TagName="div"
                                          Class="font-semibold"
                                          Style="color: #7c5a20;" />
                        </div>
                    </DemoSection>
                </TabsContent>
            </SearchableTabs>
        </div>
    </div>
</div>

@code {
    private string selectedGender = string.Empty;

    protected override void OnInitialized()
    {
        Logger.LogInformation("DictParamDemo page initialized.");
    }

    private Task OnGenderChanged(string value)
    {
        Logger.LogInformation("DictParamDemo dictionary changed. ParentName=Gender, Value={Value}", value);
        return Task.CompletedTask;
    }
}
