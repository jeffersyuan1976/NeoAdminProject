@page "/admin/file"
@layout LayoutAdmin
@using NeoAdmin.Blazor.Components
@using NeoAdmin.Blazor.Entities
@using NeoAdmin.Blazor.Services
@inject FileService FileService
@inject IToastService ToastService
@inject NavigationManager NavigationManager
@inject ILogger<File> Logger

<PageTitle>文件管理</PageTitle>

<div class="flex min-h-0 flex-1 flex-col overflow-hidden">
<CrudTable @ref="table"
           TItem="SysFile"
           Title="文件"
           PageSize="30"
           SearchPlaceholder="文件名.."
           AddText="上传"
           SaveText="完成"
           IsEdit="false"
           IsRowEdit="false"
           IsMultiSelect="true"
           DialogContentSize="CrudDialogContentSize.X4l"
           OnQuery="HandleQuery"
           OnSaveAsync="HandleSaveAsync"
           OnDeleteAsync="HandleDeleteAsync"
           OnEditClose="HandleEditClose">
    <Columns>
        <DataTableColumn TData="CrudGridRow<SysFile>"
                         TValue="long"
                         Property="@(row => row.Item.Id)"
                         Header="ID"
                         Sortable="false"
                         Width="180px" />
        <DataTableColumn TData="CrudGridRow<SysFile>"
                         TValue="string"
                         Property="@(row => row.Item.OriginFileName)"
                         Header="原始文件名"
                         Sortable="false">
            <CellTemplate Context="row">
                @Path.GetFileNameWithoutExtension(row.Item.OriginFileName)
            </CellTemplate>
        </DataTableColumn>
        <DataTableColumn TData="CrudGridRow<SysFile>"
                         TValue="string"
                         Property="@(row => row.Item.SaveFileName)"
                         Header="保存文件名"
                         Sortable="false"
                         Width="320px">
            <CellTemplate Context="row">
                <a class="text-primary hover:underline"
                   href="@NavigationManager.ToMediaUrl(row.Item.LinkUrl)"
                   target="_blank"
                   rel="noopener noreferrer"
                   @onclick:stopPropagation="true">
                    @(row.Item.SaveFileName + row.Item.Extension)
                </a>
            </CellTemplate>
        </DataTableColumn>
        <DataTableColumn TData="CrudGridRow<SysFile>"
                         TValue="string"
                         Property="@(row => row.Item.SizeFormat)"
                         Header="大小"
                         Sortable="false"
                         Width="120px" />
        <DataTableColumn TData="CrudGridRow<SysFile>"
                         TValue="string"
                         Property="@(row => row.Item.CreatedUserName)"
                         Header="创建者"
                         Sortable="false"
                         Width="120px" />
        <DataTableColumn TData="CrudGridRow<SysFile>"
                         TValue="string"
                         Property="@(_ => string.Empty)"
                         Header="创建时间"
                         Sortable="false"
                         Width="160px">
            <CellTemplate Context="row">
                @(row.Item.CreatedTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")
            </CellTemplate>
        </DataTableColumn>
    </Columns>
    <EditTemplate>
        <div class="space-y-3 p-1">
            <p class="text-sm text-muted-foreground">选择一个或多个文件后将自动上传，全部成功后对话框会自动关闭。</p>
            <NeoFileUpload @ref="fileUpload"
                           Multiple="true"
                           UploadDirectory=""
                           MaxFileSize="@MaxUploadBytes"
                           ShowLocalPreview="false"
                           ShowProgress="false"
                           EmptyHint="@null"
                           ShowToastOnSuccess="true"
                           ToastTitle="上传文件"
                           OnAllUploaded="HandleAllUploadedAsync" />
        </div>
    </EditTemplate>
    <ViewTemplate Context="item">
        <div class="space-y-4 p-1">
            @if (IsImageFile(item.Extension))
            {
                <div class="rounded-lg border bg-muted/30 p-3">
                    <p class="mb-2 text-xs text-muted-foreground">图片预览</p>
                    <img src="@NavigationManager.ToMediaUrl(item.LinkUrl)"
                         alt="@item.OriginFileName"
                         class="mx-auto max-h-[60vh] max-w-full rounded-md border bg-background object-contain" />
                </div>
            }
            else
            {
                <div class="flex items-center gap-3 rounded-lg border bg-muted/30 p-4 text-sm text-muted-foreground">
                    <LucideIcon Name="file" Size="32" Class="shrink-0 opacity-60" />
                    <span>该文件类型不支持预览，可点击下方链接在新窗口打开。</span>
                </div>
            }

            <dl class="grid grid-cols-1 gap-x-6 gap-y-3 text-sm sm:grid-cols-2">
                <div>
                    <dt class="text-muted-foreground">原始文件名</dt>
                    <dd class="mt-0.5 break-all font-medium">@item.OriginFileName</dd>
                </div>
                <div>
                    <dt class="text-muted-foreground">保存文件名</dt>
                    <dd class="mt-0.5 break-all font-medium">@(item.SaveFileName + item.Extension)</dd>
                </div>
                <div>
                    <dt class="text-muted-foreground">扩展名</dt>
                    <dd class="mt-0.5 font-medium">@item.Extension</dd>
                </div>
                <div>
                    <dt class="text-muted-foreground">大小</dt>
                    <dd class="mt-0.5 font-medium">@item.SizeFormat</dd>
                </div>
                <div>
                    <dt class="text-muted-foreground">创建者</dt>
                    <dd class="mt-0.5 font-medium">@(string.IsNullOrWhiteSpace(item.CreatedUserName) ? "-" : item.CreatedUserName)</dd>
                </div>
                <div>
                    <dt class="text-muted-foreground">创建时间</dt>
                    <dd class="mt-0.5 font-medium">@(item.CreatedTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</dd>
                </div>
            </dl>

            <div class="flex flex-wrap gap-2 pt-1">
                <a class="inline-flex items-center gap-1.5 rounded-md border px-3 py-1.5 text-sm hover:bg-muted"
                   href="@NavigationManager.ToMediaUrl(item.LinkUrl)"
                   target="_blank"
                   rel="noopener noreferrer">
                    <LucideIcon Name="external-link" Size="14" />
                    在新窗口打开
                </a>
            </div>
        </div>
    </ViewTemplate>
</CrudTable>
</div>

@code {
    private const long MaxUploadBytes = 104_857_600;

    private static readonly HashSet<string> ImageExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".png", ".jpg", ".jpeg", ".gif", ".webp", ".bmp", ".svg", ".ico", ".avif"
    };

    private CrudTable<SysFile> table = default!;
    private NeoFileUpload? fileUpload;

    private void HandleQuery(CrudQueryEventArgs<SysFile> e)
    {
        e.Select!
            .WhereIf(!string.IsNullOrWhiteSpace(e.SearchText),
                a => a.OriginFileName.Contains(e.SearchText!)
                     || a.SaveFileName.Contains(e.SearchText!)
                     || a.Extension.Contains(e.SearchText!)
                     || a.CreatedUserName.Contains(e.SearchText!))
            .OrderByDescending(a => a.CreatedTime);
    }

    private async Task HandleAllUploadedAsync(NeoFileUploadBatchResult result)
    {
        Logger.LogInformation("文件管理批量上传完成，Count={Count}", result.SuccessCount);
        await table.ReloadAsync();
        await table.CloseEditorAsync();
    }

    private async Task<bool> HandleSaveAsync(SysFile item, bool isNew)
    {
        if (fileUpload?.IsUploading == true)
        {
            ToastService.Warning("上传文件", "正在上传，请稍候。");
            return false;
        }

        await table.ReloadAsync();
        return true;
    }

    private async Task<bool> HandleDeleteAsync(SysFile item)
    {
        try
        {
            await FileService.DeleteAsync(item.Id);
            Logger.LogInformation("删除文件成功，Id={Id}，FileName={FileName}", item.Id, item.OriginFileName);
            return true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "删除文件失败，Id={Id}，FileName={FileName}", item.Id, item.OriginFileName);
            ToastService.Error("删除失败", $"{item.OriginFileName}: {ex.Message}");
            return false;
        }
    }

    private async Task HandleEditClose(SysFile _)
    {
        if (fileUpload is not null)
        {
            await fileUpload.ResetAsync();
        }
    }

    private static bool IsImageFile(string? extension)
    {
        if (string.IsNullOrWhiteSpace(extension))
        {
            return false;
        }

        string normalized = extension.StartsWith('.') ? extension : "." + extension;
        return ImageExtensions.Contains(normalized);
    }
}
