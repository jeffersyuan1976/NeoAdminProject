@namespace NeoAdmin.Blazor.Components
@typeparam TItem where TItem : class, new()
@using System.Text.Json
@using FreeSql
@using Microsoft.JSInterop
@using NeoAdmin.Blazor.Auth
@using NeoAdmin.Blazor.Entities
@using NeoAdmin.Blazor.Utils
@using NeoAdmin.Blazor.Audit
@using NeoAdmin.Blazor.Menus
@using Microsoft.Extensions.Logging
@inject IFreeSql FreeSql
@inject NeoAdminAuthService AuthService
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@inject ILoggerFactory LoggerFactory
@inject MenuPermissionService MenuPermissionService
@inject NavigationManager NavigationManager

<div class="crud-table flex flex-col flex-1 min-h-0 min-w-0">
    @HeaderContent

    @if (queryInfo.Filters.Length > 0)
    {
        <CrudSearchFilter QueryInfo="queryInfo" />
    }

    <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex flex-wrap items-center gap-3">
            @if (!Compact)
            {
                <div class="flex items-center min-h-9 mr-2">
                    <h2 class="text-lg font-semibold leading-none">@Title</h2>
                </div>
            }
            <div class="flex flex-wrap items-center gap-2">
                @if (ShowToolbarRemove && canToolbarRemove)
                {
                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Small" Title="@RemoveText"
                        Disabled="@(!HasSelectedRows)" OnClick="HandleBatchDeleteClick">
                        <LucideIcon Name="trash-2" Size="16" />
                        <span>@RemoveText@(HasSelectedRows ? $" ({selectedRows.Count})" : "")</span>
                    </Button>
                }
                @if (IsRefresh)
                {
                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Small" OnClick="HandleRefreshClick">
                        <LucideIcon Name="refresh-cw" Size="16" />
                        <span>刷新</span>
                    </Button>
                }
                @ToolbarContent
                @if (IsAdd && EditTemplate != null && canToolbarAdd)
                {
                    <Button Variant="ButtonVariant.Link" Size="@ButtonSize.Small" Title="@AddText" OnClick="HandleAddClick">
                        <LucideIcon Name="circle-plus" Size="16" />
                        <span>@AddText</span>
                    </Button>
                }
            </div>
        </div>
        @if (IsSearchText)
        {
            <form class="w-96 shrink-0" @onsubmit="HandleSearchSubmit" @onsubmit:preventDefault>
                <Input Type="InputType.Search" @bind-Value="searchText" Placeholder="@SearchPlaceholder"
                    @onblur="HandleSearchBlur" />
            </form>
        }
    </div>

    <div class="flex-1 min-h-0 min-w-0">
        <DataTable TData="CrudGridRow<TItem>" Data="@rows" ShowToolbar="false" ShowPagination="false"
            InitialPageSize="@DataTablePageSize" SelectionMode="@SelectionMode" SelectedItems="@selectedRows"
            SelectedItemsChanged="@OnSelectedRowsChanged" ColumnsVisibility="false" IsLoading="@isLoading" Dense="true"
            ColumnSizing="TableColumnSizing.Fixed" AdditionalRowAttributes="GetRowAttributes"
            Class="h-full w-full min-w-0" TableContainerClass="h-full min-w-0 overflow-x-hidden">
            <Columns>
                @if (IsWorkflowAudit)
                {
                    <DataTableColumn TData="CrudGridRow<TItem>" TValue="SysAuditStatus"
                        Property="@(row => row.Item is EntityAudited audited ? audited.AuditStatus : default)" Header="审批"
                        Sortable="false" Width="96px" Alignment="ColumnAlignment.Center">
                        <CellTemplate Context="row">
                            @if (row.Item is EntityAudited auditedItem)
                            {
                                <Badge Variant="@AuditWorkflowRules.GetStatusBadgeVariant(auditedItem.AuditStatus)"
                                    Class="@AuditWorkflowRules.GetStatusBadgeClass(auditedItem.AuditStatus)">
                                    @AuditWorkflowRules.GetStatusLabel(auditedItem.AuditStatus)
                                </Badge>
                            }
                        </CellTemplate>
                    </DataTableColumn>
                }
                @if (IsRowNumber)
                {
                    <DataTableColumn TData="CrudGridRow<TItem>" TValue="int" Property="@(row => row.RowIndex)" Header="#"
                        Width="60px" Sortable="false" />
                }
                @Columns
                @if (ShowDefaultActions)
                {
                    <DataTableColumn TData="CrudGridRow<TItem>" TValue="string" Property="@(_ => string.Empty)" Header="操作"
                        Alignment="ColumnAlignment.Center" Sortable="false" Width="120px">
                        <CellTemplate Context="row">
                            <div class="flex justify-center gap-1" @onclick:stopPropagation="true">
                                @if (RowActionsContent != null)
                                {
                                    @RowActionsContent(row)
                                }
                                @if (IsRowView && IsView && canRowView && (ViewTemplate != null || EditTemplate != null))
                                {
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" Title="@ViewText"
                                        OnClick="@(() => ViewItemAsync(row.Item))">
                                        <LucideIcon Name="eye" Size="16" />
                                        <span class="sr-only">@ViewText</span>
                                    </Button>
                                }
                                @if (IsWorkflowAudit && row.Item is EntityAudited auditedRow && auditedRow.Id > 0)
                                {
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" Title="审批"
                                        OnClick="@(() => OpenWorkflowAuditAsync(row.Item))">
                                        <LucideIcon Name="clipboard-check" Size="16" />
                                        <span class="sr-only">审批</span>
                                    </Button>
                                }
                                @if (IsRowEdit && EditTemplate != null && canRowEdit)
                                {
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" Title="@EditText"
                                        Disabled="@(IsWorkflowAudit && row.Item is EntityAudited locked && !AuditWorkflowRules.CanEdit(locked))"
                                        OnClick="@(() => EditItemAsync(row.Item))">
                                        <LucideIcon Name="pencil" Size="16" />
                                        <span class="sr-only">@EditText</span>
                                    </Button>
                                }
                                @if (IsRowRemove && canRowRemove)
                                {
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" Title="@RemoveText"
                                        Disabled="@(IsWorkflowAudit && row.Item is EntityAudited lockedRemove && !AuditWorkflowRules.CanEdit(lockedRemove))"
                                        OnClick="@(() => DeleteItemAsync(row.Item))">
                                        <LucideIcon Name="trash-2" Size="16" />
                                        <span class="sr-only">@RemoveText</span>
                                    </Button>
                                }
                            </div>
                        </CellTemplate>
                    </DataTableColumn>
                }
            </Columns>
            <EmptyTemplate>
                <div class="py-10 text-center text-sm text-muted-foreground">@NoDataText</div>
            </EmptyTemplate>
        </DataTable>
    </div>

    @if (IsPaged || FooterContent != null || total > 0)
    {
        <div class="flex flex-wrap items-center justify-between gap-3 mt-4">
            <span class="text-sm text-muted-foreground">@PageSummaryText</span>
            @if (ShowPager)
            {
                <div class="flex flex-wrap items-center gap-2">
                    <label class="flex items-center gap-2 text-sm text-muted-foreground">
                        每页
                        <select class="h-8 rounded-md border border-input bg-background px-2 text-sm" @bind="effectivePageSize"
                            @bind:after="HandlePageSizeChangedAfterBind">
                            @foreach (int size in PageSizes)
                            {
                                <option value="@size">@size</option>
                            }
                        </select>
                    </label>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Disabled="@(pageNumber <= 1)"
                        OnClick="HandleFirstPage">首页</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Disabled="@(pageNumber <= 1)"
                        OnClick="HandlePrevPage">上一页</Button>
                    <span class="text-sm">@pageNumber / @maxPageNumber</span>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Disabled="@(pageNumber >= maxPageNumber)"
                        OnClick="HandleNextPage">下一页</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Disabled="@(pageNumber >= maxPageNumber)"
                        OnClick="HandleLastPage">末页</Button>
                </div>
            }
            @FooterContent
        </div>
    }
</div>

@if (CanShowEditor)
{
    <Dialog Open="@editorOpen" OpenChanged="HandleEditorOpenChanged">
        <DialogContent Variant="DialogContentVariant.Form" Class="@DialogContentSize.ToClass()" CloseOnEscape="false">
            <DialogHeader>
                <DialogTitle>
                    @(isViewMode? ViewText : (isNewItem ? AddText : EditText)) @Title
                </DialogTitle>
                <DialogDescription>
                    @(isViewMode ? "查看当前记录。" : (isNewItem ? "创建一条新记录。" : "修改当前记录。"))
                </DialogDescription>
            </DialogHeader>
            @if (isViewMode)
            {
                <div class="max-h-[70vh] space-y-4 overflow-y-auto p-2">
                    @if (ViewTemplate != null)
                    {
                        @ViewTemplate(editor)
                    }
                    else if (EditTemplate != null)
                    {
                        <fieldset disabled class="space-y-4 opacity-90">
                            @EditTemplate(editor)
                        </fieldset>
                    }
                </div>
                <DialogFooter Class="mt-4">
                    <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button"
                        OnClick="@(() => HandleEditorOpenChanged(false))">
                        关闭
                    </Button>
                </DialogFooter>
            }
            else
            {
                <EditForm Model="@editor" OnValidSubmit="HandleSaveSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="mb-3 text-sm text-red-600" />
                    <div class="max-h-[70vh] space-y-4 overflow-y-auto p-2">
                        @EditTemplate!(editor)
                    </div>
                    <DialogFooter Class="mt-4">
                        <DialogClose AsChild>
                            <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button">
                                取消
                            </Button>
                        </DialogClose>
                        <Button Variant="ButtonVariant.Outline" Type="ButtonType.Submit">
                            @SaveText
                        </Button>
                    </DialogFooter>
                </EditForm>
            }
        </DialogContent>
    </Dialog>
}

<Dialog @bind-Open="deleteOpen">
    <DialogContent Class="sm:max-w-md">
        <DialogHeader>
            <DialogTitle>确认@RemoveText</DialogTitle>
            <DialogDescription>确定要删除此条记录吗？该操作不可撤销。</DialogDescription>
        </DialogHeader>
        <DialogFooter Class="mt-4">
            <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button" OnClick="HandleCancelDeleteClick">
                取消
            </Button>
            <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button" OnClick="HandleConfirmDeleteClick">
                @RemoveText
            </Button>
        </DialogFooter>
    </DialogContent>
</Dialog>

<Dialog @bind-Open="batchDeleteOpen">
    <DialogContent Class="sm:max-w-md">
        <DialogHeader>
            <DialogTitle>确认批量@RemoveText</DialogTitle>
            <DialogDescription>确定要删除 @batchDeleteTargets.Count 行记录吗？删除之后无法恢复。</DialogDescription>
        </DialogHeader>
        <DialogFooter Class="mt-4">
            <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button" OnClick="HandleCancelBatchDeleteClick">
                取消
            </Button>
            <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button" OnClick="HandleConfirmBatchDeleteClick">
                @RemoveText
            </Button>
        </DialogFooter>
    </DialogContent>
</Dialog>

@if (IsWorkflowAudit && auditDialogOpen && auditTarget is EntityAudited auditEntity)
{
    <Dialog Open="@auditDialogOpen" OpenChanged="HandleAuditDialogOpenChanged">
        <DialogContent Variant="DialogContentVariant.Form" Class="@DialogContentSize.ToClass()">
            <DialogHeader>
                <DialogTitle>审批 — @Title</DialogTitle>
                <DialogDescription>提交、审核、退回或拒绝当前记录。</DialogDescription>
            </DialogHeader>
            <div class="max-h-[70vh] overflow-y-auto p-2">
                <CrudAuditPanel Item="auditEntity" EntityType="typeof(TItem)" MenuPath="@WorkflowAuditMenuPath"
                    OnChanged="HandleAuditPanelChanged" />
            </div>
            <DialogFooter Class="mt-4">
                <Button Variant="ButtonVariant.Outline" Type="ButtonType.Button"
                    OnClick="@(() => HandleAuditDialogOpenChanged(false))">
                    关闭
                </Button>
            </DialogFooter>
        </DialogContent>
    </Dialog>
}

@code {
    private ILogger? _logger;
    private ILogger Logger => _logger ??=
    LoggerFactory.CreateLogger($"{typeof(CrudTable<TItem>).Name}<{typeof(TItem).Name}>");

    private bool _isRemove = true;
    private bool? _isRowRemove;
    private bool _isEdit = true;
    private bool? _isRowEdit;

    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int PageSize { get; set; } = 20;
    [Parameter] public int[] PageSizes { get; set; } = [10, 20, 30, 50, 100];

    [Parameter] public bool IsSearchText { get; set; } = true;
    [Parameter] public string SearchPlaceholder { get; set; } = "搜索...";
    [Parameter] public bool IsAdd { get; set; } = true;
    [Parameter]
    public bool IsEdit
    {
        get => _isEdit;
        set
        {
            _isEdit = value;
            if (!_isRowEdit.HasValue)
            {
                _isRowEdit = value;
            }
        }
    }

    [Parameter]
    public bool IsRowEdit
    {
        get => _isRowEdit ?? true;
        set => _isRowEdit = value;
    }

    [Parameter]
    public bool IsRemove
    {
        get => _isRemove;
        set
        {
            _isRemove = value;
            if (!_isRowRemove.HasValue)
            {
                _isRowRemove = value;
            }
        }
    }

    [Parameter]
    public bool IsRowRemove
    {
        get => _isRowRemove ?? true;
        set => _isRowRemove = value;
    }

    [Parameter] public bool IsView { get; set; } = true;
    [Parameter] public bool IsRowView { get; set; }
    [Parameter] public bool IsRefresh { get; set; } = true;
    [Parameter] public bool IsRowNumber { get; set; } = false;
    [Parameter] public bool IsShowLoading { get; set; } = true;
    [Parameter] public bool IsConfirmRemove { get; set; } = true;
    [Parameter] public bool IsMultiSelect { get; set; } = true;
    [Parameter] public bool IsSingleSelect { get; set; } = false;
    /// <summary>嵌入选择组件时隐藏标题栏，仅保留搜索与表格。</summary>
    [Parameter] public bool Compact { get; set; } = false;
    /// <summary>
    /// 嵌入 NeoInputTable 等弹窗选择器：仅同步 SelectedKeys，不触发 OnSelectChanged / SelectedKeysChanged，
    /// 也不在勾选后 StateHasChanged，避免 DataTable 选中项双向绑定死循环。
    /// </summary>
    [Parameter] public bool IsPickerMode { get; set; }
    /// <summary>跨页保持勾选：根据主键集合恢复当前页选中行。</summary>
    [Parameter] public bool KeepSelectionOnPaging { get; set; }
    /// <summary>
    /// 树形列表父子勾选联动（对齐旧版 NovaAdminTable.IsAutoSelectParent）。
    /// 需配合 LevelSelector，且数据为深度优先扁平顺序。
    /// </summary>
    [Parameter] public bool IsCascadeSelection { get; set; }
    [Parameter] public Func<TItem, int>? LevelSelector { get; set; }
    [Parameter] public Func<TItem, object>? SelectionKey { get; set; }
    [Parameter] public HashSet<object>? SelectedKeys { get; set; }
    [Parameter] public EventCallback<HashSet<object>> SelectedKeysChanged { get; set; }

    [Parameter] public string NoDataText { get; set; } = "暂无数据";
    [Parameter] public string AddText { get; set; } = "新增";
    [Parameter] public string SaveText { get; set; } = "保存";
    [Parameter] public string EditText { get; set; } = "编辑";
    [Parameter] public string ViewText { get; set; } = "查看";
    [Parameter] public string RemoveText { get; set; } = "删除";
    [Parameter] public CrudDialogContentSize DialogContentSize { get; set; } = CrudDialogContentSize.X2l;

    [Parameter] public RenderFragment? Columns { get; set; }
    [Parameter] public RenderFragment<TItem>? EditTemplate { get; set; }
    [Parameter] public RenderFragment<TItem>? ViewTemplate { get; set; }
    [Parameter] public RenderFragment<CrudGridRow<TItem>>? RowActionsContent { get; set; }
    [Parameter] public RenderFragment? ToolbarContent { get; set; }
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    [Parameter] public EventCallback<CrudQueryInfo> InitQuery { get; set; }
    [Parameter] public EventCallback<CrudQueryEventArgs<TItem>> OnQuery { get; set; }
    [Parameter] public EventCallback<CrudQueriedEventArgs<TItem>> OnQueried { get; set; }
    [Parameter] public EventCallback<TItem> OnEdit { get; set; }
    [Parameter] public EventCallback<TItem> OnEditClose { get; set; }
    [Parameter] public EventCallback<CrudConfirmEventArgs<TItem>> OnSaving { get; set; }
    [Parameter] public EventCallback<TItem> OnSaved { get; set; }
    [Parameter] public EventCallback<CrudConfirmEventArgs<TItem>> OnRemoving { get; set; }
    [Parameter] public EventCallback<CrudBatchConfirmEventArgs<TItem>> OnBatchRemoving { get; set; }
    [Parameter] public EventCallback<TItem> OnRemoved { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<TItem>> OnBatchRemoved { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<CrudGridRow<TItem>>> OnSelectChanged { get; set; }
    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }
    [Parameter] public Func<TItem, bool>? IsRowHighlighted { get; set; }

    [Parameter] public List<TItem>? ItemsSource { get; set; }
    [Parameter] public Func<Task<List<TItem>>>? LoadFunc { get; set; }
    [Parameter] public Func<TItem, bool, Task<bool>>? OnSaveAsync { get; set; }
    [Parameter] public Func<TItem, Task<bool>>? OnDeleteAsync { get; set; }
    [Parameter] public Func<TItem, bool>? CanbeSelect { get; set; }

    /// <summary>启用审批流（实体需继承 <see cref="EntityAudited"/>），自动显示「审批」列与行内审批按钮。</summary>
    [Parameter] public bool IsWorkflowAudit { get; set; }

    /// <summary>审批按钮权限所属的页面菜单路径，如 /Blog/Article。</summary>
    [Parameter] public string WorkflowAuditMenuPath { get; set; } = string.Empty;

    /// <summary>用于权限判断的菜单路径，默认取当前页面路由。</summary>
    [Parameter] public string MenuPath { get; set; } = string.Empty;

    private readonly CrudQueryInfo queryInfo = new();
    private List<CrudGridRow<TItem>> rows = new();
    private List<CrudGridRow<TItem>> selectedRows = new();
    private bool _isSyncingPickerSelection;
    private long total;
    private int pageNumber = 1;
    private int maxPageNumber = 1;
    private int effectivePageSize = 20;
    private string? searchText;
    private string? appliedSearchText;
    private bool isLoading;

    private bool editorOpen;
    private bool isNewItem;
    private bool isViewMode;
    private TItem editor = new();

    private bool deleteOpen;
    private bool batchDeleteOpen;
    private TItem? deleteTarget;
    private List<TItem> batchDeleteTargets = new();

    private bool auditDialogOpen;
    private EntityAudited? auditTarget;

    private bool canToolbarAdd = true;
    private bool canToolbarRemove = true;
    private bool canRowView = true;
    private bool canRowEdit = true;
    private bool canRowRemove = true;

    private bool IsPaged => effectivePageSize > 0;
    private int DataTablePageSize => IsPaged ? effectivePageSize : int.MaxValue;
    private bool ShowPager => IsPaged && total > effectivePageSize;
    private long PageRangeStart => total == 0 ? 0 : (pageNumber - 1L) * effectivePageSize + 1;
    private long PageRangeEnd => IsPaged
    ? Math.Min(pageNumber * (long)effectivePageSize, total)
    : total;
    private string PageSummaryText => total == 0
    ? "共 0 条"
    : IsPaged
    ? $"显示 {PageRangeStart}-{PageRangeEnd} 条，共 {total} 条"
    : $"共 {total} 条";
    private bool ShowDefaultActions =>
    RowActionsContent != null ||
    (IsRowEdit && EditTemplate != null) ||
    IsRowRemove ||
    (IsRowView && IsView && (ViewTemplate != null || EditTemplate != null));
    private bool ShowToolbarRemove => IsRemove && (IsMultiSelect || IsSingleSelect);
    private bool HasSelectedRows => selectedRows.Count > 0;
    private bool UseCascadeSelection => IsCascadeSelection && LevelSelector != null;
    private DataTableSelectionMode SelectionMode =>
    IsMultiSelect ? DataTableSelectionMode.Multiple :
    IsSingleSelect ? DataTableSelectionMode.Single :
    DataTableSelectionMode.None;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionFlagsAsync();

        effectivePageSize = PageSize;
        queryInfo.InvokeQueryAsync = async () =>
        {
            pageNumber = 1;
            await LoadAsync();
        };

        if (InitQuery.HasDelegate)
        {
            await InitQuery.InvokeAsync(queryInfo);
        }

        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadPermissionFlagsAsync();

        if (effectivePageSize != PageSize)
        {
            effectivePageSize = PageSize;
            pageNumber = 1;
            await LoadAsync();
        }
    }

    public async Task LoadAsync()
    {
        if (IsShowLoading)
        {
            isLoading = true;
            StateHasChanged();
        }

        try
        {
            if (ItemsSource != null)
            {
                await LoadInMemoryAsync(ItemsSource);
            }
            else if (LoadFunc != null)
            {
                List<TItem> items = await LoadFunc();
                await LoadInMemoryAsync(items);
            }
            else
            {
                await LoadFromDatabaseAsync();
            }

            Logger.LogInformation(
            "查询 {Entity} 完成：第 {PageNumber} 页，每页 {PageSize} 条，共 {Total} 条，搜索={SearchText}",
            typeof(TItem).Name,
            pageNumber,
            effectivePageSize,
            total,
            appliedSearchText ?? string.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "查询 {Entity} 失败", typeof(TItem).Name);
            throw;
        }

        if (OnQueried.HasDelegate)
        {
            await OnQueried.InvokeAsync(new CrudQueriedEventArgs<TItem>(
            rows.Select(row => row.Item).ToList(),
            total));
        }

        if (IsShowLoading)
        {
            isLoading = false;
        }

        StateHasChanged();
    }


    private async Task LoadPermissionFlagsAsync()
    {
        string path = ResolvePermissionMenuPath();
        if (string.IsNullOrWhiteSpace(path) || MenuPathHelper.IsExemptPage(path))
        {
            canToolbarAdd = true;
            canToolbarRemove = true;
            canRowView = true;
            canRowEdit = true;
            canRowRemove = true;
            return;
        }

        bool hasPage = await MenuPermissionService.HasPageAsync(path);
        canRowView = hasPage;
        canToolbarAdd = hasPage && await MenuPermissionService.HasButtonAsync(path, "add");
        canToolbarRemove = hasPage && await MenuPermissionService.HasButtonAsync(path, "remove");
        canRowEdit = hasPage && await MenuPermissionService.HasButtonAsync(path, "edit");
        canRowRemove = canToolbarRemove;
    }

    private string ResolvePermissionMenuPath()
    {
        if (!string.IsNullOrWhiteSpace(MenuPath))
        {
            return MenuService.NormalizePath(MenuPath);
        }

        if (!string.IsNullOrWhiteSpace(WorkflowAuditMenuPath))
        {
            return MenuService.NormalizePath(WorkflowAuditMenuPath);
        }

        string relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
        if (string.IsNullOrWhiteSpace(relativePath))
        {
            return "/";
        }

        return MenuService.NormalizePath("/" + relativePath);
    }

    public Task ReloadAsync() => LoadAsync();

    public IReadOnlyList<TItem> GetSelectedItems() =>
    selectedRows.Select(row => row.Item).ToList();

    public void ClearSelection()
    {
        selectedRows.Clear();
        StateHasChanged();
    }

    private async Task LoadFromDatabaseAsync()
    {
        ISelect<TItem> select = FreeSql.Select<TItem>();
        queryInfo.SearchText = searchText?.Trim();
        CrudQueryEventArgs<TItem> args = new(
        select,
        queryInfo.SearchText,
        queryInfo.Filters,
        pageNumber,
        effectivePageSize);

        if (OnQuery.HasDelegate)
        {
            await OnQuery.InvokeAsync(args);
        }

        total = await select.CountAsync();

        if (IsPaged)
        {
            NormalizePageNumber();
            select.Page(pageNumber, effectivePageSize);
            List<TItem> items = await select.ToListAsync();
            AssignRows(items, (pageNumber - 1) * effectivePageSize);
        }
        else
        {
            maxPageNumber = 1;
            pageNumber = 1;
            List<TItem> items = await select.ToListAsync();
            AssignRows(items, 0);
        }
    }

    private async Task LoadInMemoryAsync(List<TItem> source)
    {
        IQueryable<TItem> query = source.AsQueryable();
        queryInfo.SearchText = searchText?.Trim();
        CrudQueryEventArgs<TItem> args = new(
        query,
        queryInfo.SearchText,
        queryInfo.Filters,
        pageNumber,
        effectivePageSize);

        if (OnQuery.HasDelegate)
        {
            await OnQuery.InvokeAsync(args);
            query = args.Queryable ?? query;
        }

        total = query.Count();

        if (IsPaged)
        {
            NormalizePageNumber();

            List<TItem> items = query
            .Skip((pageNumber - 1) * effectivePageSize)
            .Take(effectivePageSize)
            .ToList();
            AssignRows(items, (pageNumber - 1) * effectivePageSize);
        }
        else
        {
            maxPageNumber = 1;
            pageNumber = 1;
            AssignRows(query.ToList(), 0);
        }
    }

    private void NormalizePageNumber()
    {
        maxPageNumber = Math.Max(1, (int)Math.Ceiling((double)total / effectivePageSize));
        if (pageNumber > maxPageNumber)
        {
            pageNumber = maxPageNumber;
        }

        if (pageNumber < 1)
        {
            pageNumber = 1;
        }
    }

    private void AssignRows(List<TItem> items, int startIndex)
    {
        rows = items.Select((item, index) => new CrudGridRow<TItem>
        {
            RowIndex = startIndex + index + 1,
            Item = item
        }).ToList();

        if (KeepSelectionOnPaging && SelectionKey != null && SelectedKeys is { Count: > 0 })
        {
            selectedRows = rows
            .Where(row => SelectedKeys.Contains(SelectionKey(row.Item)))
            .ToList();
        }
        else if (!KeepSelectionOnPaging)
        {
            selectedRows.Clear();
        }
    }

    public void SetSelectedKeys(IEnumerable<object> keys)
    {
        SelectedKeys = keys.ToHashSet();
        if (SelectionKey != null && rows.Count > 0)
        {
            selectedRows = rows
            .Where(row => SelectedKeys.Contains(SelectionKey(row.Item)))
            .ToList();
        }
    }

    private async Task HandleSaveSubmit(EditContext _)
    {
        if (isViewMode)
        {
            return;
        }

        if (OnSaving.HasDelegate)
        {
            CrudConfirmEventArgs<TItem> confirmArgs = new(editor);
            await OnSaving.InvokeAsync(confirmArgs);
            if (confirmArgs.Cancel) return;
        }

        if (IsWorkflowAudit && editor is EntityAudited auditedEditor && !AuditWorkflowRules.CanEdit(auditedEditor))
        {
            ToastService.Error("保存失败", "正在审批中，无法修改！");
            return;
        }

        if (OnSaveAsync != null)
        {
            bool success = await OnSaveAsync(editor, isNewItem);
            if (!success)
            {
                Logger.LogWarning(
                "保存 {Entity} 失败：{EntityDesc}",
                typeof(TItem).Name,
                EntityLogHelper.Describe(editor));
                return;
            }
        }
        else
        {
            if (isNewItem)
            {
                await FreeSql.Insert(editor).ExecuteAffrowsAsync();
            }
            else
            {
                await FreeSql.Update<TItem>().SetSource(editor).ExecuteAffrowsAsync();
            }
        }

        Logger.LogInformation(
        "{Action} {Entity} 成功：{EntityDesc}",
        isNewItem ? "新增" : "更新",
        typeof(TItem).Name,
        EntityLogHelper.Describe(editor));

        if (OnSaved.HasDelegate)
        {
            await OnSaved.InvokeAsync(editor);
        }

        await CloseEditorAsync();
        await LoadAsync();
    }

