    // NeoUI DataTable 默认行样式；AdditionalRowAttributes 若单独设置 class 会覆盖默认值，需一并带上。
    private const string DataTableBodyRowBaseClass =
    "group border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted";

    private Dictionary<string, object> GetRowAttributes(CrudGridRow<TItem> row)
    {
        Dictionary<string, object> attrs = new()
        {
            ["data-row-index"] = row.RowIndex
        };

        List<string> classes = new();
        if (IsRowHighlighted?.Invoke(row.Item) == true)
        {
            classes.Add("bg-accent/60");
        }

        if (OnRowClick.HasDelegate)
        {
            classes.Add("cursor-pointer");
            attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(
            this,
            () => OnRowClick.InvokeAsync(row.Item));
        }

        if (classes.Count > 0)
        {
            classes.Insert(0, DataTableBodyRowBaseClass);
            attrs["class"] = string.Join(' ', classes);
        }

        if (IsView || (IsEdit && EditTemplate != null))
        {
            attrs["ondblclick"] = EventCallback.Factory.Create<MouseEventArgs>(
            this,
            () => HandleRowDoubleClick(row));
        }

        return attrs;
    }

    private bool CanShowEditor => EditTemplate != null || ViewTemplate != null;
