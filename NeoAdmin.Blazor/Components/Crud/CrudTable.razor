    private Task OnSelectedRowsChanged(IReadOnlyCollection<CrudGridRow<TItem>> items)
    {
        if (_isSyncingPickerSelection)
        {
            return Task.CompletedTask;
        }

        List<CrudGridRow<TItem>> incoming = items.ToList();
        if (IsSameRowSelection(incoming, selectedRows))
        {
            return Task.CompletedTask;
        }

        if (UseCascadeSelection)
        {
            ApplyCascadeRowSelection(items);
        }
        else
        {
            selectedRows = incoming;
        }

        return OnSelectedRowsAfterBind();
    }

    private bool IsSameRowSelection(
    IReadOnlyList<CrudGridRow<TItem>> incoming,
    IReadOnlyList<CrudGridRow<TItem>> current)
    {
        if (incoming.Count != current.Count)
        {
            return false;
        }

        if (incoming.Count == 0)
        {
            return true;
        }

        if (SelectionKey != null)
        {
            HashSet<object> incomingKeys = incoming.Select(row => SelectionKey(row.Item)).ToHashSet();
            HashSet<object> currentKeys = current.Select(row => SelectionKey(row.Item)).ToHashSet();
            return incomingKeys.SetEquals(currentKeys);
        }

        for (int i = 0; i < incoming.Count; i++)
        {
            if (!ReferenceEquals(incoming[i], current[i]))
            {
                return false;
            }
        }

        return true;
    }

    /// <summary>检测单行勾选变化并联动子孙/祖先（参照 NeoAllocTable / NovaAdminTable）。</summary>
    private void ApplyCascadeRowSelection(IReadOnlyCollection<CrudGridRow<TItem>> items)
    {
        HashSet<CrudGridRow<TItem>> previous = selectedRows.ToHashSet();
        List<CrudGridRow<TItem>> incoming = items.ToList();
        List<CrudGridRow<TItem>> added = incoming.Where(row => !previous.Contains(row)).ToList();
        List<CrudGridRow<TItem>> removed = previous.Where(row => !incoming.Contains(row)).ToList();

        if (added.Count == 1 && removed.Count == 0)
        {
            int index = rows.IndexOf(added[0]);
            if (index >= 0)
            {
                ApplyCascadeSelectionAt(index, true);
                return;
            }
        }

        if (removed.Count == 1 && added.Count == 0)
        {
            int index = rows.IndexOf(removed[0]);
            if (index >= 0)
            {
                ApplyCascadeSelectionAt(index, false);
                return;
            }
        }

        selectedRows = incoming;
    }

    private void ApplyCascadeSelectionAt(int index, bool selected)
    {
        HashSet<CrudGridRow<TItem>> selectedSet = selectedRows.ToHashSet();
        TreeCascadeSelectionHelper.ApplyCascade(
        rows,
        index,
        selected,
        row => LevelSelector!(row.Item),
        (row, isSelected) =>
        {
            if (isSelected)
            {
                selectedSet.Add(row);
            }
            else
            {
                selectedSet.Remove(row);
            }
        },
        row => selectedSet.Contains(row));

        selectedRows = rows.Where(selectedSet.Contains).ToList();
    }

    private async Task OnSelectedRowsAfterBind()
    {
        if (CanbeSelect != null)
        {
            selectedRows = selectedRows.Where(row => CanbeSelect(row.Item)).ToList();
        }

        if (SelectionKey != null && KeepSelectionOnPaging)
        {
            HashSet<object> nextSelectedKeys = SelectedKeys is null
            ? new HashSet<object>()
            : new HashSet<object>(SelectedKeys);
            HashSet<object> pageKeys = rows.Select(row => SelectionKey(row.Item)).ToHashSet();
            HashSet<object> selectedOnPage = selectedRows
            .Select(row => SelectionKey(row.Item))
            .ToHashSet();

            foreach (object pageKey in pageKeys)
            {
                if (selectedOnPage.Contains(pageKey))
                {
                    nextSelectedKeys.Add(pageKey);
                }
                else
                {
                    nextSelectedKeys.Remove(pageKey);
                }
            }

            bool keysChanged = SelectedKeys is null || !SelectedKeys.SetEquals(nextSelectedKeys);
            if (keysChanged)
            {
                SelectedKeys = nextSelectedKeys;
                if (SelectedKeysChanged.HasDelegate)
                {
                    await SelectedKeysChanged.InvokeAsync(nextSelectedKeys);
                }
            }
        }

        if (IsPickerMode)
        {
            return;
        }

        if (OnSelectChanged.HasDelegate)
        {
            await OnSelectChanged.InvokeAsync(selectedRows);
        }

        await InvokeAsync(StateHasChanged);
    }

