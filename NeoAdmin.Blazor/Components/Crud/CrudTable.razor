    private async Task SearchAsync()
    {
        string? normalizedSearchText = string.IsNullOrWhiteSpace(searchText)
        ? null
        : searchText.Trim();

        if (string.Equals(appliedSearchText, normalizedSearchText, StringComparison.Ordinal))
        {
            return;
        }

        searchText = normalizedSearchText;
        appliedSearchText = normalizedSearchText;
        pageNumber = 1;
        Logger.LogInformation("搜索 {Entity}：{SearchText}", typeof(TItem).Name, normalizedSearchText ?? string.Empty);
        await LoadAsync();
    }

