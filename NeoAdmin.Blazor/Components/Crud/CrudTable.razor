    }

    private async Task DeleteItemsAsync(List<TItem> items, bool single)
    {
        if (items.Count == 0) return;

        if (IsWorkflowAudit)
        {
            TItem? locked = items.FirstOrDefault(item => item is EntityAudited audited && !AuditWorkflowRules.CanEdit(audited));
            if (locked is not null)
            {
                ToastService.Error(RemoveText, "正在审批中，无法删除！");
                return;
            }
        }

        string? blockMessage = await GetBuiltInDeleteBlockMessageAsync(items);
        if (blockMessage is not null)
        {
            ToastService.Error(RemoveText, blockMessage);
            return;
        }

        if (single && OnRemoving.HasDelegate)
        {
            CrudConfirmEventArgs<TItem> confirmArgs = new(items[0]);
            await OnRemoving.InvokeAsync(confirmArgs);
            if (confirmArgs.Cancel) return;
        }

        if (!single && OnBatchRemoving.HasDelegate)
        {
            CrudBatchConfirmEventArgs<TItem> confirmArgs = new(items);
            await OnBatchRemoving.InvokeAsync(confirmArgs);
            if (confirmArgs.Cancel) return;
        }

        foreach (TItem item in items)
        {
            if (!await DeleteEntityAsync(item))
            {
                Logger.LogWarning("删除 {Entity} 失败：{EntityDesc}", typeof(TItem).Name, EntityLogHelper.Describe(item));
                return;
            }

            Logger.LogInformation("删除 {Entity} 成功：{EntityDesc}", typeof(TItem).Name, EntityLogHelper.Describe(item));

            if (OnRemoved.HasDelegate)
            {
                await OnRemoved.InvokeAsync(item);
            }
        }

        if (!single && OnBatchRemoved.HasDelegate)
        {
            await OnBatchRemoved.InvokeAsync(items);
        }

        selectedRows.Clear();
        await LoadAsync();
    }

    private async Task<string?> GetBuiltInDeleteBlockMessageAsync(IReadOnlyList<TItem> items)
    {
        if (items.Count == 0 || items[0] is not SysUser)
        {
            return null;
        }

        List<SysUser> users = items.Cast<SysUser>().ToList();
        long? currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId.HasValue && users.Any(a => a.Id == currentUserId.Value))
        {
            return "不能删除当前登录的账号";
        }

        if (users.Any(a => a.IsSystem))
        {
            return "不能删除系统用户";
        }

        return null;
    }

    private async Task<bool> DeleteEntityAsync(TItem item)
    {
        if (OnDeleteAsync != null)
        {
            return await OnDeleteAsync(item);
        }

        if (item is SysUser user)
        {
            await FreeSql.Delete<SysRoleUser>().Where(a => a.UserId == user.Id).ExecuteAffrowsAsync();
            await FreeSql.Delete<SysUser>(user).ExecuteAffrowsAsync();
            return true;
        }

        await FreeSql.Delete<TItem>(item).ExecuteAffrowsAsync();
        return true;
    }

    private async Task<long?> GetCurrentUserIdAsync()
    {
        string? token = await JSRuntime.InvokeAsync<string?>("neoAdminAuth.getToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            return null;
        }

        ApiResult<UserSummaryResponse> result = await AuthService.CheckAsync(token);
        return result.Succeeded ? result.Data!.Id : null;
    }

