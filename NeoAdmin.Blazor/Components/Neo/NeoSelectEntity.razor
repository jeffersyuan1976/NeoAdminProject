@namespace NeoAdmin.Blazor.Components
@typeparam TItem where TItem : class
@typeparam TKey
@using FreeSql
@using FreeSql.Internal.Model
@using NeoAdmin.Blazor.Extensions
@using NeoAdmin.Blazor.Models
@using NeoAdmin.Blazor.Utils
@inject IFreeSql FreeSql

<NativeSelect TValue="string"
              Class="w-full"
              Placeholder="@Placeholder"
              Disabled="@Disabled"
              @bind-Value="boundKey"
              @bind-Value:after="SyncKeyFromBoundValue">
    @if (items != null)
    {
        @foreach (NeoAdminItem<TItem> item in items)
        {
            <NativeSelectOption Value="@FormatKey(GetPrimaryKey(item.Value))">
                @((item.Level > 1 ? new string('\u3000', item.Level - 1) : string.Empty))@GetLabel(item.Value)
            </NativeSelectOption>
        }
    }
</NativeSelect>

@code {
    [Parameter]
    public TKey Value { get; set; } = default!;

    [Parameter]
    public EventCallback<TKey> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<TKey> OnValueChanged { get; set; }

    [Parameter]
    public Func<TItem, string>? DisplayText { get; set; }

    [Parameter]
    public List<TItem>? Source { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>未选择时显示的文字。</summary>
    [Parameter]
    public string Placeholder { get; set; } = "请选择..";

    [Parameter]
    public Action<ISelect<TItem>>? OnQuery { get; set; }

    private List<NeoAdminItem<TItem>>? items;
    private ColumnInfo? firstStringColumn;
    private string boundKey = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        NeoEntitySelectHelper.EnsureSinglePrimaryKey<TItem, TKey>(FreeSql);
        firstStringColumn = NeoEntitySelectHelper.GetFirstStringColumn(FreeSql, typeof(TItem));
        await LoadItemsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        boundKey = FormatKey(Value);
        if (Source != null)
        {
            await LoadItemsAsync();
        }
    }

    private async Task LoadItemsAsync()
    {
        List<TItem> source = Source ?? await QueryItemsAsync();
        items = source.ToNeoAdminItemList(FreeSql);
    }

    private async Task<List<TItem>> QueryItemsAsync()
    {
        ISelect<TItem> query = FreeSql.Select<TItem>();
        OnQuery?.Invoke(query);
        return await query.ToListAsync();
    }

    private async Task SyncKeyFromBoundValue()
    {
        if (string.IsNullOrEmpty(boundKey))
        {
            Value = default!;
        }
        else
        {
            Type targetType = Nullable.GetUnderlyingType(typeof(TKey)) ?? typeof(TKey);
            Value = (TKey)Convert.ChangeType(boundKey, targetType);
        }

        await ValueChanged.InvokeAsync(Value);
        await OnValueChanged.InvokeAsync(Value);
    }

    private TKey GetPrimaryKey(TItem item) =>
        NeoEntitySelectHelper.GetPrimaryKey<TItem, TKey>(FreeSql, item);

    private string GetLabel(TItem item)
    {
        string? text = DisplayText?.Invoke(item);
        if (!string.IsNullOrWhiteSpace(text))
        {
            return text;
        }

        if (firstStringColumn != null)
        {
            return firstStringColumn.GetValue(item)?.ToString() ?? FormatKey(GetPrimaryKey(item));
        }

        return FormatKey(GetPrimaryKey(item));
    }

    private static string FormatKey(TKey key) => key?.ToString() ?? string.Empty;
}
