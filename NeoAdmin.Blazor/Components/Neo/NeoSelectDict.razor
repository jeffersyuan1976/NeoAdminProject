@namespace NeoAdmin.Blazor.Components
@using FreeSql
@using NeoAdmin.Blazor.Entities
@inject IFreeSql FreeSql

<NativeSelect TValue="string"
              Class="w-full"
              Placeholder="@Placeholder"
              Disabled="@Disabled"
              @bind-Value="Value"
              @bind-Value:after="NotifyValueChanged">
    @foreach (SysDict item in items)
    {
        <NativeSelectOption Value="@GetOptionValue(item)">@GetDisplayLabel(item)</NativeSelectOption>
    }
</NativeSelect>

@code {
    [Parameter]
    public string ParentName { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string> OnValueChanged { get; set; }

    [Parameter]
    public List<SysDict>? Source { get; set; }

    [Parameter]
    public Func<SysDict, string>? DisplayText { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "请选择..";

    private List<SysDict> items = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Source is not null)
        {
            items = Source;
            return;
        }

        if (string.IsNullOrWhiteSpace(ParentName))
        {
            items = new List<SysDict>();
            return;
        }

        items = await FreeSql.Select<SysDict>()
            .Include(a => a.Parent)
            .Where(a => a.Parent!.Name == ParentName)
            .OrderBy(a => a.Sort)
            .ToListAsync();
    }

    private async Task NotifyValueChanged()
    {
        await ValueChanged.InvokeAsync(Value);
        await OnValueChanged.InvokeAsync(Value);
    }

    private string GetOptionValue(SysDict item) =>
        DisplayText?.Invoke(item)
        ?? (string.IsNullOrWhiteSpace(item.Value) ? item.Name : item.Value);

    private string GetDisplayLabel(SysDict item) =>
        string.IsNullOrWhiteSpace(item.Name) ? item.Value : item.Name;
}
