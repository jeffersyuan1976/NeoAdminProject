@namespace NeoAdmin.Blazor.Components
@typeparam TItem where TItem : class
@typeparam TChild where TChild : class
@typeparam TKey
@using FreeSql
@using NeoAdmin.Blazor.Utils
@using Microsoft.Extensions.Logging
@inject IFreeSql FreeSql
@inject IToastService ToastService
@inject ILoggerFactory LoggerFactory

<Dialog Open="@(Item != null)" OpenChanged="HandleOpenChanged">
  <DialogContent Variant="DialogContentVariant.Form" Class="@DialogContentSize.ToClass()" CloseOnEscape="false">
    <div class="flex max-h-[min(90vh,48rem)] flex-col">
      <div class="shrink-0">
        <DialogHeader>
          <DialogTitle>@(string.IsNullOrWhiteSpace(Title) ? "分配" : Title)</DialogTitle>
          <DialogDescription>勾选需要关联的项，然后确认保存。</DialogDescription>
        </DialogHeader>
      </div>
      @if (Item != null)
      {
        <div class="flex min-h-0 flex-1 flex-col gap-3 overflow-hidden">
          @if (IsSearchText)
          {
            <div class="shrink-0">
              <Input Type="InputType.Search" Placeholder="@SearchPlaceholder" @bind-Value="searchText"
                @bind-Value:after="LoadChoicesAsync" />
            </div>
          }
          <div
            class="max-h-50vh min-h-0 flex-1 space-y-2 overflow-x-hidden overflow-y-auto overscroll-contain rounded-md border p-3">
            @if (choices.Count == 0)
            {
              <p class="text-sm text-muted-foreground">暂无可选项</p>
            }
            else
            {
              @foreach (TChild child in choices)
              {
                TKey key = KeySelector(child);
                <div class="flex items-center gap-2" style="@GetIndentStyle(child)">
                  <Checkbox Checked="@IsSelected(key)" CheckedChanged="@(value => ToggleAsync(key, value))"
                    Id="@($"neo-alloc-{key}")" />
                  <Label For="@($"neo-alloc-{key}")" Class="cursor-pointer font-normal">
                    @if (RowTemplate != null)
                    {
                      @RowTemplate(child)
                    }
                    else
                    {
                      @DisplayText(child)
                    }
                  </Label>
                </div>
              }
            }
          </div>
          <p class="shrink-0 text-sm text-muted-foreground">已选 @selectedKeys.Count 项</p>
        </div>
        <div class="shrink-0">
          <DialogFooter Class="mt-4 flex flex-wrap justify-between gap-2">
            <Button Variant="ButtonVariant.Outline" OnClick="ResetSelection">重置</Button>
            <div class="flex gap-2">
              <Button Variant="ButtonVariant.Outline" OnClick="Close">取消</Button>
              <Button Variant="ButtonVariant.Default" OnClick="SaveAsync">确认选择 @selectedKeys.Count 项</Button>
            </div>
          </DialogFooter>
        </div>
      }
    </div>
  </DialogContent>
</Dialog>

@code {
  private ILogger? _logger;
  private ILogger Logger => _logger ??= LoggerFactory.CreateLogger($"{typeof(NeoAllocTable<,,>).Name}<{typeof(TItem).Name},{typeof(TChild).Name}>");

  [Parameter] public TItem? Item { get; set; }
  [Parameter] public EventCallback<TItem?> ItemChanged { get; set; }
  [Parameter] public string Title { get; set; } = string.Empty;
  [Parameter] public CrudDialogContentSize DialogContentSize { get; set; } = CrudDialogContentSize.X2l;
  [Parameter] public bool IsSearchText { get; set; } = true;
  [Parameter] public string SearchPlaceholder { get; set; } = "搜索..";
  [Parameter] public Func<TChild, TKey> KeySelector { get; set; } = default!;
  [Parameter] public Func<TChild, string> DisplayText { get; set; } = default!;
  [Parameter] public Func<TChild, int>? LevelSelector { get; set; }
  /// <summary>
  /// 树形列表父子勾选联动（对齐旧版 NovaAdminTable.IsAutoSelectParent）。
  /// 需配合 LevelSelector，且 choices 为深度优先扁平顺序。
  /// </summary>
  [Parameter] public bool IsCascadeSelection { get; set; } = true;
  [Parameter] public RenderFragment<TChild>? RowTemplate { get; set; }
  [Parameter] public EventCallback<CrudQueryEventArgs<TChild>> OnQuery { get; set; }
  /// <summary>自定义加载可选项（如树形扁平列表）；设置后优先于 OnQuery + FreeSql。</summary>
  [Parameter] public Func<string?, Task<List<TChild>>>? LoadChoicesFunc { get; set; }
  [Parameter] public Func<TItem, Task<IReadOnlyCollection<TKey>>>? LoadSelectedKeysAsync { get; set; }
  [Parameter] public Func<TItem, IReadOnlyCollection<TKey>, Task<bool>>? OnSaveAsync { get; set; }

  private readonly HashSet<TKey> selectedKeys = new();
  private List<TChild> choices = new();
  private string? searchText;
  private TItem? loadedForItem;

  protected override async Task OnParametersSetAsync()
  {
    if (Item == null)
    {
      loadedForItem = null;
      choices.Clear();
      selectedKeys.Clear();
      return;
    }

    if (!ReferenceEquals(Item, loadedForItem))
    {
      loadedForItem = Item;
      await LoadSelectedAsync();
      await LoadChoicesAsync();
    }
  }

  private async Task LoadSelectedAsync()
  {
    selectedKeys.Clear();
    if (Item == null || LoadSelectedKeysAsync == null)
    {
      return;
    }

    IReadOnlyCollection<TKey> keys = await LoadSelectedKeysAsync(Item);
    foreach (TKey key in keys)
    {
      selectedKeys.Add(key);
    }
  }

  private async Task LoadChoicesAsync()
  {
    if (LoadChoicesFunc != null)
    {
      choices = await LoadChoicesFunc(searchText?.Trim());
      return;
    }

    ISelect<TChild> select = FreeSql.Select<TChild>();
    CrudQueryEventArgs<TChild> args = new(
    select,
    searchText?.Trim(),
    Array.Empty<CrudFilterInfo>(),
    1,
    -1);

    if (OnQuery.HasDelegate)
    {
      await OnQuery.InvokeAsync(args);
    }

    choices = await select.ToListAsync();
  }

  private bool IsSelected(TKey key) => selectedKeys.Contains(key);

  private bool UseCascadeSelection => IsCascadeSelection && LevelSelector != null;

  private Task ToggleAsync(TKey key, bool selected)
  {
    if (!UseCascadeSelection)
    {
      SetSelected(key, selected);
      return Task.CompletedTask;
    }

    int index = FindChoiceIndex(key);
    if (index < 0)
    {
      SetSelected(key, selected);
      return Task.CompletedTask;
    }

    ApplyCascadeSelection(index, selected);
    return Task.CompletedTask;
  }

  private void ApplyCascadeSelection(int index, bool selected)
  {
    TreeCascadeSelectionHelper.ApplyCascade(
      choices,
      index,
      selected,
      item => LevelSelector!(item),
      (item, isSelected) => SetSelected(KeySelector(item), isSelected),
      item => IsSelected(KeySelector(item)));
  }

  private int FindChoiceIndex(TKey key)
  {
    for (int index = 0; index < choices.Count; index++)
    {
      if (EqualityComparer<TKey>.Default.Equals(KeySelector(choices[index]), key))
      {
        return index;
      }
    }

    return -1;
  }

  private void SetSelected(TKey key, bool selected)
  {
    if (selected)
    {
      selectedKeys.Add(key);
    }
    else
    {
      selectedKeys.Remove(key);
    }
  }

  private void ResetSelection() => selectedKeys.Clear();

  /// <summary>与菜单管理列表一致：每层 18px，不依赖 Tailwind 是否扫描到 pl-*。</summary>
  private string GetIndentStyle(TChild child)
  {
    int level = LevelSelector?.Invoke(child) ?? 0;
    return level > 0 ? $"padding-left:{level * 18}px" : string.Empty;
  }

  private async Task SaveAsync()
  {
    if (Item == null)
    {
      return;
    }

    if (OnSaveAsync == null)
    {
      ToastService.Error("分配", "未配置 OnSaveAsync，无法保存分配结果。");
      return;
    }

    bool success = await OnSaveAsync(Item, selectedKeys.ToList());
    if (success)
    {
      Logger.LogInformation(
        "分配保存成功：{ItemDesc}，已选 {Count} 项",
        EntityLogHelper.Describe(Item),
        selectedKeys.Count);
      ToastService.Success("分配", "保存成功");
      await Close();
    }
    else
    {
      Logger.LogWarning(
        "分配保存失败：{ItemDesc}，已选 {Count} 项",
        EntityLogHelper.Describe(Item),
        selectedKeys.Count);
    }
  }

  private async Task Close()
  {
    loadedForItem = null;
    choices.Clear();
    selectedKeys.Clear();
    searchText = null;
    await ItemChanged.InvokeAsync(default);
  }

  private async Task HandleOpenChanged(bool open)
  {
    if (!open)
    {
      await Close();
    }
  }
}
