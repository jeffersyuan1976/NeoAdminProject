@inject NavigationManager NavigationManager
@implements IDisposable

<Tabs Value="@activeTab"
      ValueChanged="HandleTabChanged"
      DefaultValue="@DefaultValue"
      Class="@Class">
    @ChildContent
</Tabs>

@code {
    private const string TabQueryKey = "tab";

    [Parameter, EditorRequired]
    public string DefaultValue { get; set; } = string.Empty;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string activeTab = string.Empty;
    private bool syncingFromUri;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        activeTab = ResolveTabFromUri() ?? DefaultValue;
    }

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(activeTab))
        {
            activeTab = DefaultValue;
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        string tab = ResolveTabFromUri() ?? DefaultValue;
        if (tab == activeTab)
        {
            return;
        }

        syncingFromUri = true;
        activeTab = tab;
        syncingFromUri = false;
        InvokeAsync(StateHasChanged);
    }

    private void HandleTabChanged(string value)
    {
        if (syncingFromUri || activeTab == value)
        {
            return;
        }

        activeTab = value;
        UpdateUriTab(value);
    }

    private string? ResolveTabFromUri()
    {
        Uri uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (string.IsNullOrWhiteSpace(uri.Query))
        {
            return null;
        }

        foreach (string part in uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            string[] pair = part.Split('=', 2);
            if (pair.Length == 2 && pair[0].Equals(TabQueryKey, StringComparison.OrdinalIgnoreCase))
            {
                return Uri.UnescapeDataString(pair[1]);
            }
        }

        return null;
    }

    private void UpdateUriTab(string tab)
    {
        Uri uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        string path = uri.GetLeftPart(UriPartial.Path);
        string href = string.IsNullOrWhiteSpace(tab) || tab == DefaultValue
            ? path
            : $"{path}?{TabQueryKey}={Uri.EscapeDataString(tab)}";

        if (NavigationManager.Uri == href || NavigationManager.Uri == NavigationManager.ToAbsoluteUri(href).ToString())
        {
            return;
        }

        NavigationManager.NavigateTo(href, replace: true);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
